# OpenAI / OpenAI-compatible API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI-compatible API base URL (optional)
# Set this to use a custom endpoint (e.g., vLLM, LocalAI, Ollama, etc.)
# Example: OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_API_BASE=

# Default model (optional, overridable via --model CLI argument)
# Recommended models:
# - gpt-4o-mini (fast and cheap, good for most tasks)
# - gpt-4o (more capable but more expensive)
# - gpt-5.1-mini (latest)
# OPENAI_MODEL=gpt-4o

# --- OpenAI-Compatible Providers ---
# DeepSeek (set both API_BASE and MODEL):
# OPENAI_API_BASE=https://api.deepseek.com
# OPENAI_MODEL=deepseek-v4-flash
#
# Other OpenAI-compatible backends (vLLM, LocalAI, Ollama, etc.):
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Google Gemini API Key (AI Studio)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key (optional, for Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter API Key (optional, for OpenRouter routing)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
